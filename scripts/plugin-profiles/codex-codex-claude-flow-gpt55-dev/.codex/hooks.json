{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "apply_patch|Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/graphify-query-hook.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/post-tool-use-tracker.sh"
          }
        ]
      }
    ]
  }
}
