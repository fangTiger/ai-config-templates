{
  "enableAllProjectMcpServers": true,
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true,
    "superpowers@claude-plugins-official": false,
    "everything-claude-code@everything-claude-code": false,
    "oh-my-claudecode@omc": false,
    "code-review@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "pinecone@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Edit:*",
      "Write:*",
      "MultiEdit:*",
      "NotebookEdit:*",
      "Bash:*"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(rm -rf /:*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "apply_patch|Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.codex/hooks/graphify-query-hook.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.codex/hooks/post-tool-use-tracker.sh"
          }
        ]
      }
    ]
  }
}
